{
  "realm": "wallet-demo",
  "enabled": true,
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "wallet-mock",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "protocolMappers": [
        {
          "name": "credential-family-name-id-token",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usersessionmodel-note-mapper",
          "consentRequired": false,
          "config": {
            "user.session.note": "credentialFamilyName",
            "claim.name": "credential_family_name",
            "jsonType.label": "String",
            "id.token.claim": "true"
          }
        }
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["default-roles-wallet-demo"]
    }
  ]
}
